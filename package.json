{
  "name": "backend_assessment",
  "version": "1.0.0",
  "description": "Backend developer assessment",
  "main": "dist/server.js",
  "scripts": {
    "worker": "ts-node --transpile-only src/workers/jobWorker.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "ts-node --transpile-only src/db/runMigration.ts",
    "check:tables": "ts-node --transpile-only src/db/checkTables.ts",
    "seed": "ts-node --transpile-only src/db/seed.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "echo \"No tests yet\"",
    "check:orgs": "ts-node --transpile-only src/db/checkOrganizations.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
